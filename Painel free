-- 7. SISTEMA DE ARRASTAR (MOBILE)
local UIS = game:GetService("UserInputService")
local dragging, dragStart, startPos

Janela.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Janela.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Janela.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

Janela.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- 8. LÓGICA DE VERIFICAÇÃO DA KEY + EXECUÇÃO DO SCRIPT EXTERNO
Botao.MouseButton1Click:Connect(function()
    local key = CampoKey.Text
    
    if string.find(key, "^RBX") and string.find(key, "DEV$") then
        Botao.Text = "KEY VÁLIDA! CARREGANDO..."
        Botao.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        
        wait(1.5)
        tela:Destroy() -- Fecha o seu painel de login
        
        -- EXECUTA O SCRIPT DO GITHUB APÓS O LOGIN
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/axiusofc/Tutorial-de-script-lua/refs/heads/main/Tutorial%20de%20script"))()
        end)
        
        print("Script carregado com sucesso!")
    else
        local corOriginal = Botao.BackgroundColor3
        Botao.Text = "KEY INVÁLIDA!"
        Botao.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        wait(1)
        Botao.Text = "ENTRAR"
        Botao.BackgroundColor3 = corOriginal
    end
end)
